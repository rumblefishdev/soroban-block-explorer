{
  "envName": "production",
  "awsRegion": "us-east-1",
  "vpcCidr": "10.1.0.0/16",
  "availabilityZones": ["us-east-1a", "us-east-1b"],
  "natType": "gateway",
  "natGatewayCount": 1,

  "dbInstanceClass": "t4g.micro",
  "dbAllocatedStorage": 20,
  "dbMultiAz": false,
  "dbDeletionProtection": true,
  "dbBackupRetentionDays": 30,
  "dbProxy": true,
  "kmsEncryption": true,

  "apiLambdaMemory": 256,
  "apiLambdaTimeout": 30,
  "indexerLambdaMemory": 512,
  "indexerLambdaTimeout": 60,

  "galexieCpu": 4096,
  "galexieMemory": 16384,
  "galexieEphemeralStorage": 30,
  "galexieDesiredCount": 1,
  "stellarNetworkPassphrase": "Public Global Stellar Network ; September 2015",
  "ecsLogRetentionDays": 90,
  "galexieStopTimeout": 120,
  "ecsExecEnabled": false,
  "galexieImageTag": "latest",
  "galexieBackfillEnabled": true,

  "apiGatewayThrottleRate": 50,
  "apiGatewayThrottleBurst": 100,
  "apiGatewayCacheEnabled": false,
  "apiGatewayCacheSize": "0.5",
  "apiGatewayCacheTtlImmutable": 3600,
  "apiGatewayCacheTtlMutable": 10,
  "apiGatewayPartnerDailyQuota": 10000,

  "domainName": "sorobanscan.rumblefish.dev",
  "apiDomainName": "api.sorobanscan.rumblefish.dev",
  "hostedZoneId": "CHANGE_ME",
  "hostedZoneName": "sorobanscan.rumblefish.dev",
  "certificateArn": "CHANGE_ME",
  "enableWaf": true,
  "enableBasicAuth": false,
  "cloudFrontWafRateLimit": 10000,
  "apiWafRateLimit": 2000
}
