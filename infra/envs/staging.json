{
  "envName": "staging",
  "awsRegion": "us-east-1",
  "vpcCidr": "10.0.0.0/16",
  "availabilityZones": ["us-east-1a", "us-east-1b"],
  "natType": "gateway",
  "natGatewayCount": 1,

  "dbInstanceClass": "t4g.micro",
  "dbAllocatedStorage": 20,
  "dbMultiAz": false,
  "dbDeletionProtection": false,
  "dbBackupRetentionDays": 7,
  "dbProxy": true,
  "kmsEncryption": false,

  "apiLambdaMemory": 256,
  "apiLambdaTimeout": 30,
  "indexerLambdaMemory": 512,
  "indexerLambdaTimeout": 60,

  "galexieCpu": 1024,
  "galexieMemory": 4096,
  "galexieEphemeralStorage": 30,
  "galexieDesiredCount": 1,
  "stellarNetworkPassphrase": "Test SDF Network ; September 2015",
  "ecsLogRetentionDays": 30,
  "galexieStopTimeout": 120,
  "ecsExecEnabled": true,
  "galexieImageTag": "latest",
  "galexieBackfillEnabled": false,

  "apiGatewayThrottleRate": 50,
  "apiGatewayThrottleBurst": 100,
  "apiGatewayCacheEnabled": false,
  "apiGatewayCacheSize": "0.5",
  "apiGatewayCacheTtlImmutable": 3600,
  "apiGatewayCacheTtlMutable": 10,
  "apiGatewayPartnerDailyQuota": 10000
}
